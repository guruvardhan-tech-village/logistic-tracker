# Environment variables template for the React Frontend

# The base URL path for the application.
# If deploying to GitHub Pages at https://username.github.io/repo-name/, set this to /repo-name/
# For Vercel, Netlify, or local development, you can leave this blank or set to /
VITE_BASE_PATH=/

# The Base URL for the backend REST API
# Example (Local): http://localhost:8080/api
# Example (Render): https://your-render-backend-url.onrender.com/api
VITE_API_URL=http://localhost:8080/api

# The WebSocket URL for real-time telemetry updates
# Example (Local): ws://localhost:8080/ws
# Example (Render): wss://your-render-backend-url.onrender.com/ws
VITE_WS_URL=ws://localhost:8080/ws
